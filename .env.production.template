# 🌍 CONFIGURACIÓN PARA EL SERVIDOR DE CASA
# Copia este archivo como '.env' en tu servidor y ajusta los valores.

# Sustituye 'localhost' por la IP de tu PC servidor (ej: 192.168.1.50)
# para que el móvil y otros PCs puedan conectar correctamente.

# 🌐 FRONTEND (WEB)
NEXT_PUBLIC_USER_SERVICE_URL=http://localhost:3000
NEXT_PUBLIC_FINANCE_SERVICE_URL=http://localhost:8000

# 🔑 SEGURIDAD (USER SERVICE)
JWT_SECRET=cambia_esto_por_algo_seguro_y_largo
MONGODB_URI=mongodb://mongodb:27017/users_db
APP_ENV=prod

# 💰 FINANZAS (FINANCE SERVICE)
FINANCE_APP_SECRET=clave_secreta_para_symfony
FINANCE_DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}?serverVersion=16&charset=utf8

# 🐘 POSTGRES (DATABASE)
POSTGRES_USER=root
POSTGRES_PASSWORD=root
POSTGRES_DB=homeos_db

# 👤 PGADMIN (Panel para ver la DB de Postgres)
PGADMIN_DEFAULT_EMAIL=admin@homeos.local
PGADMIN_DEFAULT_PASSWORD=admin

# 🍃 MONGO EXPRESS (Panel para ver MongoDB)
ME_CONFIG_BASICAUTH_USERNAME=admin
ME_CONFIG_BASICAUTH_PASSWORD=admin

# 🔑 GOOGLE OAUTH (Opcional)
GOOGLE_CLIENT_ID=tu_client_id_de_google
GOOGLE_CLIENT_SECRET=tu_client_secret_de_google
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
